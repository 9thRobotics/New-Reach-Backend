# Application Configurations
SKIP_PREFLIGHT_CHECK=true
PORT=3000

# Contract Information
REACT_APP_CONTRACT_ADDRESS=0xYourContractAddressHere

# MongoDB Configuration
MONGO_URI=mongodb+srv://your_mongo_connection_string

# Sepolia Network Configuration
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Private Key (DO NOT COMMIT TO GITHUB)
PRIVATE_KEY=your_private_wallet_key

# Etherscan API Key
ETHERSCAN_API_KEY=your_etherscan_api_key

# Goerli Network Configuration
GOERLI_RPC_URL=https://goerli.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Infura API Key
INFURA_API_KEY=your_infura_api_key

# Backend Configuration
VITE_BACKEND_URL=https://your-backend-url.com

# Security Keys
PRIVACY_KEY=your_privacy_key
JWT_SECRET=your_jwt_secret

# Wallet Address
WALLET_ADDRESS=0xYourWalletAddressHere

# API Key Secret
API_KEY_SECRET=your_api_key_secret
